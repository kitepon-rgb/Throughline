{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Throughline Monitor",
      "detail": "フォルダを開いた瞬間に token-monitor を専用ターミナルで自動起動する",
      "type": "shell",
      "command": "node src/token-monitor.mjs",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "throughline",
        "close": false,
        "echo": false,
        "focus": false,
        "showReuseMessage": false,
        "clear": true
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "problemMatcher": []
    }
  ]
}
